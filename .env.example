# AloneChat Environment Configuration
# Copy this file to .env and modify the values as needed

# JWT Configuration
JWT_SECRET=your-secret-key-change-in-production

# ClickHouse Configuration
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=9000
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=alonechat
CLICKHOUSE_ENABLED=true

# ClickHouse Docker Configuration (used by docker-compose)
CLICKHOUSE_DEFAULT_ACCESS_MANAGEMENT=1

# Multi-Thread Configuration
AC_PROCESS_WORKERS=15
AC_THREAD_WORKERS=60
AC_IO_WORKERS=9
AC_DB_WORKERS=6

CONTAINER_MODE=false

CORS_ALLOW_ORIGINS="http://localhost:8123,http://localhost:8766"
CORS_ALLOW_CREDENTIALS=true
